# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Parfum CI

# Supabase public browser-safe values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Supabase server-only values. Never expose these with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=your-secret-or-service-role-key
SUPABASE_STORAGE_BUCKET=product-images

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL="Parfum CI <notifications@example.com>"

# Operations
ADMIN_EMAIL_ALLOWLIST=admin@example.com
AUDIT_LOG_RETENTION_DAYS=365
ORDER_TRACKING_TOKEN_SECRET=replace-with-a-long-random-secret

# Payments
PAYMENT_PROVIDER=manual
MOBILE_MONEY_INSTRUCTIONS="Orange Money / MTN / Wave payment instructions"
COD_ENABLED=true

# Playwright admin auth setup. Use only local/test staff credentials.
# Storage state is written to ignored playwright/.auth files.
PLAYWRIGHT_ADMIN_EMAIL=
PLAYWRIGHT_ADMIN_PASSWORD=
